SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RUN_SCRAPER_1=true
RUN_SCRAPER_2=true
PERSIST_LOCAL_OUTPUTS=false
UPSERT_CHUNK_SIZE=500
SCRAPER_2_DEP_WORKERS=1
SCRAPER_2_LIMA_WORKERS=1
SCRAPER_2_REQUEST_TIMEOUT=30
SCRAPER_2_VIEWSTATE_RETRIES=3
SCRAPER_2_USE_SELENIUM_FALLBACK=true
SCRAPER_2_SELENIUM_WAIT_TIMEOUT=20
